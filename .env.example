# VYV — environment variables template
# Copy to .env (or configure in your hosting provider) and fill in the values.
# NEVER commit the real .env file.

# --- Required: database ---
# PostgreSQL connection string
DATABASE_URL=

# --- Required: authentication (Clerk) ---
# On Replit these are provided automatically by the managed Clerk integration.
# Outside Replit, create a Clerk app at https://clerk.com and use its keys.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# --- Required: AI (Gemini) ---
# On Replit these are provided automatically by the Gemini integration proxy.
# Outside Replit, use a Google AI Studio API key and the public base URL.
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=

# --- Required: object storage (Replit App Storage / Google Cloud Storage) ---
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# --- Required: encryption for stored OAuth tokens ---
# Any long random string (e.g. `openssl rand -hex 32`)
TOKEN_ENCRYPTION_KEY=

# --- Optional: Explorer content feature (currently disabled) ---
EXPLORER_ENABLED=false
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- Optional ---
# Public origin of the deployed app (used for OAuth callbacks / links)
CANONICAL_ORIGIN=
LOG_LEVEL=
